APP_NAME=Manji
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production: APP_URL=https://my.manjiapp.ir
ADMIN_DASHBOARD_URL=http://localhost:3000
# Production: ADMIN_DASHBOARD_URL=https://admin.manjiapp.ir
ADMIN_DASHBOARD_ENFORCE_ORIGIN=false

# Story editor — markdown/json source files (defaults to storage/app/manji-stories in config).
# On Manji production, point this at the folder that contains story subdirectories
# (each story is a folder with episode_*/ markdown files and characters_and_objects.json).
# Phase C bulk import copies from ../manji-stories/staging into this path:
#   php artisan stories:import-old --dry-run
#   php artisan stories:import-old --only=86
STORY_EDITOR_STORIES_PATH=/home/my@manjiapp.ir/storage/app/manji-stories
#
# Local machine → server API import (no direct DB). Set bootstrap secret ON SERVER only:
#   php artisan admin:create-local-import-token --generate-bootstrap-secret
# LOCAL_IMPORT_BOOTSTRAP_SECRET=
# LOCAL_IMPORT_SUPER_ADMIN_PHONE=
# On local dev machine after bootstrap:
# LOCAL_IMPORT_API_BASE_URL=https://your-server.example/api/admin
# LOCAL_IMPORT_API_TOKEN=
#
# After changing .env: php artisan config:clear && php artisan config:cache
ADMIN_ENABLE_LEGACY_API_ALIASES=false
ADMIN_LEGACY_API_SUNSET_AT=2026-12-31T23:59:59Z
ADMIN_LEGACY_API_MIGRATION_DOC_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=manji
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Activity logs: sync insert on shared hosting (no queue worker). Set false if workers run.
ACTIVITY_LOG_SYNC=true

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Melipayamak SMS (OTP, templates, bulk campaigns)
# ---------------------------------------------------------------------------
MELIPAYAMAK_USERNAME=
# Quote the value if it contains # (unquoted values truncate at # in .env files)
MELIPAYAMAK_PASSWORD=
MELIPAYAMK_SENDER=50002710008883
MELIPAYAMK_VERIFICATION_TEMPLATE=485459

# SMS logging & campaigns (see config/sms.php)
SMS_LOGGING_ENABLED=true
SMS_CAMPAIGN_QUEUE=sms
SMS_CAMPAIGN_MAX_RECIPIENTS=10000
SMS_CAMPAIGN_DAILY_LIMIT=3
SMS_CAMPAIGN_SEND_DELAY_MS=200
SMS_CAMPAIGN_CHUNK_SIZE=50

# Delivery status polling (Melipayamak GetDeliveries2)
SMS_DELIVERY_POLLING_ENABLED=true
SMS_DELIVERY_INITIAL_DELAY_SECONDS=60
SMS_DELIVERY_MAX_AGE_HOURS=48
SMS_DELIVERY_BATCH_SIZE=100
SMS_DELIVERY_JOB_TRIES=5
SMS_DELIVERY_JOB_BACKOFF_SECONDS=120

# After deploy / seed:
# php artisan db:seed --class=SmsPermissionSeeder
# php artisan db:seed --class=SmsSystemTemplateSeeder
# php artisan queue:work --queue=sms

# Myket in-app purchase (server-side X-Access-Token — never expose in Flutter)
MYKET_PACKAGE_NAME=com.avinpishtazan.manji
MYKET_API_KEY=
MYKET_API_BASE_URL=https://developer.myket.ir/api/partners/applications

# Firebase Cloud Messaging — server push uses service account JSON only (not google-services.json)
# project_id must match manji-flutter/android/app/google-services.json
FIREBASE_PROJECT_ID=manjiapp-3028e
FIREBASE_SERVICE_ACCOUNT_PATH=storage/app/manjiapp-3028e-firebase-adminsdk.json
FIREBASE_USE_V1_API=true
PUSH_NOTIFICATIONS_ENABLED=true
