# Laravel — document root is the project folder (not public/).
# Route "/" to the front controller; everything else goes through public/.

# cPanel + LiteSpeed: use standard ea-php82 handler so CloudLinux PHP Selector extensions apply.
# (The ___litespeed suffix loaded PDO only, without pdo_mysql.)
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Avoid 403 when "/" maps to the public/ directory (directory listing disabled).
    RewriteRule ^$ public/index.php [L]

    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

DirectoryIndex index.php index.html
